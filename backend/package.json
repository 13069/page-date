{
  "name": "pagedate-api",
  "version": "1.0.0",
  "description": "PageDate backend — CMS metadata resolver with SaaS rate limiting",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "prestart": "node -e \"import fs from 'fs'; if (!fs.existsSync('data/users.json')) fs.copyFileSync('data/users.json.example','data/users.json');\"",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "add-user": "node scripts/add-user.js",
    "render-env": "node scripts/render-env-help.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  }
}
